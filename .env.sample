# Telegram bot token, required
TELEGRAM_BOT_TOKEN=

# HTTP server port for the bot and Mini App
PORT=3000

# MongoDB, optional. If missing, Pocket Signal runs in limited in-memory demo mode.
MONGODB_URI=

# CookMyBots AI Gateway, optional. If missing, AI explanations are disabled safely.
COOKMYBOTS_AI_ENDPOINT=https://api.cookmybots.com/api/ai
COOKMYBOTS_AI_KEY=
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2
CONCURRENCY=20

# Optional generic market data key. If missing or provider fails, demo market data is used and labeled.
MARKET_DATA_API_KEY=

# Optional Mini App public launch URL. If missing, Render URL or PUBLIC_BASE_URL may be used.
WEBAPP_PUBLIC_URL=

# Optional comma-separated Telegram user IDs for /admin and Admin screen.
ADMIN_TELEGRAM_IDS=

# Auto-synced env keys detected from process.env usage:
PUBLIC_BASE_URL=
RENDER_EXTERNAL_URL=

