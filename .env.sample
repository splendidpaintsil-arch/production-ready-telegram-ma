# Telegram bot token, required
TELEGRAM_BOT_TOKEN=

# HTTP server port for the bot and Mini App
PORT=3000

# MongoDB, optional. If missing, the bot runs with limited in-memory persistence.
MONGODB_URI=

# CookMyBots AI Gateway. Endpoint is a base URL; do not add /chat.
COOKMYBOTS_AI_ENDPOINT=https://api.cookmybots.com/api/ai
COOKMYBOTS_AI_KEY=
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2
CONCURRENCY=20

# Optional generic live market-data provider. If either value is missing or the provider fails, demo/sample data is clearly labeled.
MARKET_DATA_ENDPOINT=
MARKET_DATA_API_KEY=

# Optional Mini App public launch URL. If missing, Render URL or PUBLIC_BASE_URL is used when available.
WEBAPP_PUBLIC_URL=
PUBLIC_BASE_URL=
RENDER_EXTERNAL_URL=

# Optional comma-separated Telegram user IDs for /admin and Admin screen.
ADMIN_TELEGRAM_IDS=
